<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.481" Build="14.0.3456.2"><BatchSequence><Batch><Statements><StmtSimple StatementText="WITH AllPrincipals AS (&#xa;&#x9;&#x9;SELECT @principalIdLoc AS Id,&#xa;&#x9;&#x9;&#x9;   @principalIdLoc AS PId&#xa;&#x9;&#x9;UNION ALL&#xa;&#x9;&#x9;SELECT &#xa;&#x9;&#x9;&#x9;child.UserGroupPrincipalId AS Id,&#xa;&#x9;&#x9;&#x9;parent.Id AS PId&#xa;&#x9;&#x9;FROM PrincipalUserGroup child &#xa;&#x9;&#x9;INNER JOIN Principal PG ON child.UserGroupPrincipalId = PG.Id AND PG.DeletedTime IS NULL&#xa;&#x9;&#x9;INNER JOIN AllPrincipals parent&#xa;&#x9;&#x9;  &#x9; ON parent.Id = child.PrincipalId&#xa;&#x9;&#x9;INNER JOIN Principal UP &#xa;&#x9;&#x9;&#x9; ON parent.Id = UP.Id&#xa;&#x9;&#x9;WHERE child.DeletedTime IS NULL AND UP.DeletedTime IS NULL&#xa;&#x9;)&#xa;&#x9;&#xa;&#x9;SELECT DISTINCT&#xa;&#x9;&#x9;P.RoleId,&#xa;&#x9;&#x9;P.ResourceId,&#xa;&#x9;&#x9;G.PrincipalId AS GroupPrincipalId,&#xa;&#x9;&#x9;G.Name AS GroupName,&#xa;&#x9;&#x9;Ro.Name AS RoleName,&#xa;&#x9;&#x9;Ro.AggregatedRoleId AS AggregatedRole,&#xa;&#x9;&#x9;Res.AggregatedResourceId AS AggregatedResource,&#xa;&#x9;&#x9;P.CreatedTime AS CreatedTime,&#xa;&#x9;&#x9;ByU.PrincipalId AS CreatedById,&#xa;&#x9;&#x9;ByU.Name AS CreatedByName,&#xa;&#x9;&#x9;P.IpRegEx&#x9;&#x9;&#x9;&#xa;&#x9;FROM AllPrincipals&#xa;&#x9;INNER JOIN Privilege P ON AllPrincipals.Id = P.PrincipalId&#xa;&#x9;INNER JOIN dbo.[Role] Ro ON P.RoleId = Ro.Id&#xa;&#x9;INNER JOIN dbo.[Resource] Res ON P.ResourceId = Res.Id&#xa;&#x9;INNER JOIN [User] ByU ON P.CreatedBy = ByU.PrincipalId &#xa;&#x9;LEFT OUTER JOIN [UserGroup] G&#xa;&#x9;&#x9;ON P.PrincipalId = G.PrincipalId &#xa;&#x9;&#x9;AND G.PrincipalId &lt;&gt; @principalIdLoc&#xa;&#x9;    AND (@roleIdLoc IS NULL OR P.RoleId = @roleIdLoc)&#xa;&#x9;WHERE P.DeletedTime IS NULL&#xa;&#x9;AND Ro.DeletedTime IS NULL&#xa;&#x9;AND Res.DeletedTime IS NULL&#xa;&#x9;ORDER BY GroupName, AggregatedRole, AggregatedResource" StatementId="