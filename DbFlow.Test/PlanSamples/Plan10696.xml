<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.599" Build="17.0.4015.4"><BatchSequence><Batch><Statements><StmtSimple StatementText="UPDATE P&#xa;    SET &#xa;&#x9;    P.LastModifiedTime = LatestData.LastModifiedTime,&#xa;        P.LastModifiedBy = LatestData.LastModifiedBy&#xa;    FROM dbo.[Principal] P&#xa;    INNER JOIN (&#xa;    -- Get the latest update per principal(s)?&#xa;        SELECT &#xa;            PrincipalId, &#xa;            LastModifiedTime, &#xa;            LastModifiedBy,&#xa;            ROW_NUMBER() OVER (PARTITION BY PrincipalId ORDER BY LastModifiedTime DESC) as Rank&#xa;        FROM (&#xa;            SELECT &#xa;                I.PrincipalId,&#xa;                (CASE WHEN src.[DeletedTime] &gt; src.CreatedTime THEN src.DeletedTime ELSE src.CreatedTime END) [LastModifiedTime],&#xa;                (CASE WHEN src.[DeletedTime] &gt; src.CreatedTime THEN src.DeletedBy ELSE src.CreatedBy END) [LastModifiedBy]&#xa;            FROM Inserted I&#xa;            INNER JOIN dbo.[Privilege] src ON I.PrincipalId = src.PrincipalId &#xa;                               AND I.RoleId = src.RoleId&#xa;                               AND I.ResourceId = src.ResourceId&#xa;        ) AS DerivedValues&#xa;    ) AS LatestData ON P.[Id] = LatestData.PrincipalId&#xa;    -- most recent row per Principal&#xa;  WHERE LatestData.Rank = 1 &#xa;        AND (P.[LastModifiedTime] IS NULL OR LatestData.[LastModifiedTime] &gt;= P.[LastModifiedTime])" StatementId="1" StatementCompId="5" StatementType="UPDATE" StatementSqlHandle="0x090095E0A5E65918E8EBD8FE33A5B2B548100000000000000000000000000000000000000000000000000000" DatabaseContextSettingsId="12" ParentObjectId="594101157" StatementParameterizationType="0" RetrievedFromCache="false" StatementSubTreeCost="0.0231477" StatementEstRows="1" SecurityPolicyApplied="false" StatementOptmLevel="FULL" QueryHash="0xE267E83A872ED9BE" QueryPlanHash="0xE5B31488A0E80552" StatementOptmEarlyAbortReason="GoodE